  metadata            Json?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  owner    Owner     @relation(fields: [ownerId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])

  @@index([ownerId])
  @@map("portfolio_investments")
}

// ==========================================
// 19. IoT
// ==========================================

enum DeviceType {
  SMART_LOCK
  THERMOSTAT
  NOISE_MONITOR
  CAMERA_OUTDOOR
  SENSOR
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  LOW_BATTERY
  DEVICE_ERROR
}

model IotDevice {
  id            String       @id @default(uuid())
  propertyId    String       @map("property_id")
  unitId        String?      @map("unit_id")
  deviceType    DeviceType   @map("device_type")
  provider      String
  deviceId      String       @map("device_id")
  name          String
  status        DeviceStatus @default(OFFLINE)
  credentials   Json?        // Encrypted
  lastSeenAt    DateTime?    @map("last_seen_at")
  batteryLevel  Int?         @map("battery_level")
  metadata      Json?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  property Property      @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])

  @@index([propertyId])
  @@map("iot_devices")
}

// ==========================================
// 20. AI
// ==========================================

enum AiProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
}

model AiConversation {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  contextType String?    @map("context_type")
  contextId   String?    @map("context_id")
  provider    AiProvider
  model       String
  messages    Json       // Array of {role, content, timestamp}
  tokensUsed  Int        @default(0) @map("tokens_used")
  costUsd     Decimal    @default(0) @map("cost_usd")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("ai_conversations")
}

model AiCache {
  id         String   @id @default(uuid())
  cacheKey   String   @unique @map("cache_key")
  provider   String
  promptHash String   @map("prompt_hash")
  response   Json
  tokensUsed Int      @map("tokens_used")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("ai_cache")
}

// ==========================================
// 21. PROPERTY SCORING
// ==========================================

model PropertyScore {
  id                     String   @id @default(uuid())
  propertyId             String   @map("property_id")
  periodMonth            Int      @map("period_month")
  periodYear             Int      @map("period_year")
  overallScore           Decimal  @map("overall_score")
  occupancyScore         Decimal  @map("occupancy_score")
  revenueScore           Decimal  @map("revenue_score")
  maintenanceScore       Decimal  @map("maintenance_score")
  guestSatisfactionScore Decimal  @map("guest_satisfaction_score")
  responseTimeScore      Decimal  @map("response_time_score")
  breakdown              Json
  createdAt              DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, periodMonth, periodYear])
  @@map("property_scores")
}

// ==========================================
// 22. REPORTS
// ==========================================

enum ReportType {
  OWNER_MONTHLY
  FINANCIAL_SUMMARY
  OCCUPANCY
  REVENUE
  MAINTENANCE_REPORT
  CUSTOM
}

enum ReportFormat {
  PDF
  EXCEL
  BOTH
}

model ReportTemplate {
  id           String       @id @default(uuid())
  name         String
  type         ReportType
  config       Json         // columns, filters, grouping, charts
  outputFormat ReportFormat @map("output_format")
  isSystem     Boolean      @default(false) @map("is_system")
  createdById  String?      @map("created_by_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  schedules ReportSchedule[]
  generated GeneratedReport[]

  @@map("report_templates")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

model ReportSchedule {
  id               String    @id @default(uuid())
  templateId       String    @map("template_id")
  ownerId          String?   @map("owner_id")
  propertyId       String?   @map("property_id")
  frequency        Frequency
  deliveryChannels Json      @map("delivery_channels") // [{channel, recipients}]
  nextRunAt        DateTime  @map("next_run_at")
  lastRunAt        DateTime? @map("last_run_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  template ReportTemplate @relation(fields: [templateId], references: [id])
  owner    Owner?         @relation(fields: [ownerId], references: [id])
  property Property?      @relation(fields: [propertyId], references: [id])
  generated GeneratedReport[]

  @@map("report_schedules")
}

model GeneratedReport {
  id          String       @id @default(uuid())
  templateId  String       @map("template_id")
  scheduleId  String?      @map("schedule_id")
  ownerId     String?      @map("owner_id")
  fileUrl     String       @map("file_url")
  fileFormat  ReportFormat @map("file_format")
  periodStart DateTime     @map("period_start") @db.Date
  periodEnd   DateTime     @map("period_end") @db.Date
  generatedAt DateTime     @default(now()) @map("generated_at")
  metadata    Json?

  template ReportTemplate  @relation(fields: [templateId], references: [id])
  schedule ReportSchedule? @relation(fields: [scheduleId], references: [id])
  owner    Owner?          @relation(fields: [ownerId], references: [id])

  @@map("generated_reports")
}

// ==========================================
// 23. NOTIFICATIONS
// ==========================================

enum NotificationChannel {
  NOTIF_IN_APP
  NOTIF_EMAIL
  NOTIF_WHATSAPP
  NOTIF_SMS
  NOTIF_PUSH
}

model Notification {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  type      String
  title     String
  body      String
  data      Json?
  channel   NotificationChannel
  isRead    Boolean             @default(false) @map("is_read")
  readAt    DateTime?           @map("read_at")
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model NotificationPreference {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  channelEmail     Boolean  @default(true) @map("channel_email")
  channelWhatsapp  Boolean  @default(true) @map("channel_whatsapp")
  channelSms       Boolean  @default(false) @map("channel_sms")
  reportMonthly    Boolean  @default(true) @map("report_monthly")
  reportQuarterly  Boolean  @default(true) @map("report_quarterly")
  reportAnnual     Boolean  @default(true) @map("report_annual")
  approvalAlerts   Boolean  @default(true) @map("approval_alerts")
  approvalThreshold Decimal? @map("approval_threshold")
  marketingEmails  Boolean  @default(true) @map("marketing_emails")
  quietHoursStart  String?  @map("quiet_hours_start") // "22:00"
  quietHoursEnd    String?  @map("quiet_hours_end")   // "08:00"
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

// ==========================================
// 24. WEBHOOKS
// ==========================================

enum WebhookStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  WEBHOOK_FAILED
}

model WebhookEvent {
  id          String        @id @default(uuid())
  source      String
  eventType   String        @map("event_type")
  payload     Json
  status      WebhookStatus @default(RECEIVED)
  error       String?
  attempts    Int           @default(0)
  processedAt DateTime?     @map("processed_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([source, eventType])
  @@index([status])
  @@map("webhook_events")
}

// ==========================================
// 25. API CONNECTORS
// ==========================================

enum AuthType {
  API_KEY
  OAUTH2
  BASIC
  BEARER
  CUSTOM
}

model ApiConnector {
  id                   String   @id @default(uuid())
  name                 String
  category             String   // 'ota', 'ai', 'payment', 'crm', etc.
  authType             AuthType @map("auth_type")
  baseUrl              String   @map("base_url")
  credentialsEncrypted Json?    @map("credentials_encrypted")
  healthUrl            String?  @map("health_url")
  isActive             Boolean  @default(true) @map("is_active")
  lastHealthCheck      DateTime? @map("last_health_check")
  metadata             Json?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("api_connectors")
}

// ==========================================
// 26. TRANSLATIONS (Dynamic Content)
// ==========================================

model Translation {
  id                String   @id @default(uuid())
  entityType        String   @map("entity_type")
  entityId          String   @map("entity_id")
  field             String
  locale            String
  value             String
  isAutoTranslated  Boolean  @default(false) @map("is_auto_translated")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([entityType, entityId, field, locale])
  @@index([entityType, entityId])
  @@map("translations")
}

// ==========================================
// 27. ACCOUNTING
// ==========================================

enum EntryType {
  DEBIT
  CREDIT
}

model AccountingEntry {
  id              String    @id @default(uuid())
  entryType       EntryType @map("entry_type")
  accountCode     String    @map("account_code")
  amount          Decimal
  currency        String    @default("EUR")
  description     String
  referenceType   String?   @map("reference_type")
  referenceId     String?   @map("reference_id")
  propertyId      String?   @map("property_id")
  ownerId         String?   @map("owner_id")
  periodMonth     Int       @map("period_month")
  periodYear      Int       @map("period_year")
  syncedToExternal Boolean  @default(false) @map("synced_to_external")
  externalId      String?   @map("external_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([accountCode, periodYear, periodMonth])
  @@map("accounting_entries")
}

enum AccountingProvider {
  QUICKBOOKS
  XERO
  ACC_CUSTOM
}

enum IntegrationStatus {
  INT_CONNECTED
  INT_DISCONNECTED
  INT_ERROR
}

model AccountingIntegration {
  id           String             @id @default(uuid())
  provider     AccountingProvider
  status       IntegrationStatus  @default(INT_DISCONNECTED)
  credentials  Json?              // Encrypted
  settings     Json?
  lastSyncedAt DateTime?          @map("last_synced_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@map("accounting_integrations")
}
