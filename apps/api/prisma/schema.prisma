generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. USERS & AUTH
// ==========================================

enum UserRole {
  SUPER_ADMIN
  PROPERTY_MANAGER
  MAINTENANCE
  OWNER
  VIP_STAR
  AFFILIATE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  phone              String?     @unique
  passwordHash       String      @map("password_hash")
  firstName          String      @map("first_name")
  lastName           String      @map("last_name")
  avatarUrl          String?     @map("avatar_url")
  role               UserRole    @default(OWNER)
  status             UserStatus  @default(PENDING_VERIFICATION)
  twoFactorEnabled   Boolean     @default(false) @map("two_factor_enabled")
  twoFactorSecret    String?     @map("two_factor_secret")
  preferredLocale    String      @default("en") @map("preferred_locale")
  timezone           String      @default("Europe/Athens")
  lastLoginAt        DateTime?   @map("last_login_at")
  emailVerifiedAt    DateTime?   @map("email_verified_at")
  phoneVerifiedAt    DateTime?   @map("phone_verified_at")
  metadata           Json?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  deletedAt          DateTime?   @map("deleted_at")

  // Relations
  refreshTokens      RefreshToken[]
  auditLogs          AuditLog[]
  owner              Owner?
  managedProperties  Property[]      @relation("PropertyManager")
  reportedMaintenance MaintenanceRequest[] @relation("MaintenanceReporter")
  assignedMaintenance MaintenanceRequest[] @relation("MaintenanceAssignee")
  createdTasks       Task[]          @relation("TaskCreator")
  taskAssignments    TaskAssignment[]
  uploadedDocuments  Document[]      @relation("DocumentUploader")
  approvedExpenses   ExpenseRecord[] @relation("ExpenseApprover")
  calendarBlocks     CalendarBlock[]
  notifications      Notification[]
  aiConversations    AiConversation[]
  loyaltyMember      LoyaltyMember?
  affiliateProfile   AffiliateProfile?
  paymentMethods     PaymentMethod[]
  threadAssignments  MessageThread[] @relation("ThreadAssignee")
  sentMessages       GuestMessage[]  @relation("MessageSender")

  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  tokenHash   String    @map("token_hash")
  deviceInfo  String?   @map("device_info")
  ipAddress   String?   @map("ip_address")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ==========================================
// 2. PROPERTIES
// ==========================================

enum PropertyType {
  VILLA
  APARTMENT
  STUDIO
  HOUSE
  BUILDING
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  ONBOARDING
  MAINTENANCE
  ARCHIVED
}

model Property {
  id                   String         @id @default(uuid())
  ownerId              String         @map("owner_id")
  managerId            String?        @map("manager_id")
  internalCode         String         @unique @map("internal_code")
  name                 String
  slug                 String         @unique
  description          Json?          // Multilingual: {en: "", he: "", ...}
  propertyType         PropertyType   @map("property_type")
  status               PropertyStatus @default(ONBOARDING)
  addressLine1         String         @map("address_line1")
  addressLine2         String?        @map("address_line2")
  city                 String
  stateRegion          String         @map("state_region")
  postalCode           String         @map("postal_code")
  country              String         @default("GR")
  latitude             Decimal?
  longitude            Decimal?
  bedrooms             Int
  bathrooms            Int
  maxGuests            Int            @map("max_guests")
  areaSqm              Decimal?       @map("area_sqm")
  floor                Int?
  amenities            Json?          // Array of strings
  houseRules           Json?          @map("house_rules") // Multilingual
  checkInTime          String         @default("15:00") @map("check_in_time")
  checkOutTime         String         @default("11:00") @map("check_out_time")
  minStayNights        Int            @default(1) @map("min_stay_nights")
  baseNightlyRate      Decimal        @map("base_nightly_rate")
  currency             String         @default("EUR")
  cleaningFee          Decimal        @default(0) @map("cleaning_fee")
  managementFeePercent Decimal        @default(25) @map("management_fee_percent")
  minimumMonthlyFee    Decimal        @default(0) @map("minimum_monthly_fee")
  purchasePrice        Decimal?       @map("purchase_price")
  purchaseDate         DateTime?      @map("purchase_date")
  propertyScore        Decimal?       @map("property_score")
  scoreUpdatedAt       DateTime?      @map("score_updated_at")
  icalImportUrl        String?        @map("ical_import_url")
  icalExportToken      String         @unique @default(uuid()) @map("ical_export_token")
  smartLockId          String?        @map("smart_lock_id")
  wifiName             String?        @map("wifi_name")
  wifiPassword         String?        @map("wifi_password") // Encrypted
  parkingInstructions  Json?          @map("parking_instructions") // Multilingual
  emergencyContacts    Json?          @map("emergency_contacts")
  metadata             Json?
  publishedAt          DateTime?      @map("published_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")

  // Relations
  owner               Owner          @relation(fields: [ownerId], references: [id])
  manager             User?          @relation("PropertyManager", fields: [managerId], references: [id])
  images              PropertyImage[]
  units               PropertyUnit[]
  bookings            Booking[]
  calendarBlocks      CalendarBlock[]
  icalFeeds           IcalFeed[]
  incomeRecords       IncomeRecord[]
  expenseRecords      ExpenseRecord[]
  documents           Document[]
  maintenanceRequests MaintenanceRequest[]
  tasks               Task[]
  customFieldValues   CustomFieldValue[]
  channelConnections  ChannelConnection[]  @relation("PropertyChannels")
  ratePlans           RatePlan[]
  seasonalRates       SeasonalRate[]
  otaRateRules        OtaRateRule[]
  revenueRules        RevenueRule[]       @relation("PropertyRevenueRules")
  propertyScores      PropertyScore[]
  reportSchedules     ReportSchedule[]
  messageThreads      MessageThread[]
  iotDevices          IotDevice[]
  portfolioInvestments PortfolioInvestment[]
  directBookingSettings DirectBookingSetting?
  managementFeeCalcs  ManagementFeeCalculation[]

  @@index([ownerId, status])
  @@index([city, status])
  @@map("properties")
}

model PropertyImage {
  id            String   @id @default(uuid())
  propertyId    String   @map("property_id")
  unitId        String?  @map("unit_id")
  url           String
  thumbnailUrl  String?  @map("thumbnail_url")
  caption       Json?    // Multilingual
  sortOrder     Int      @default(0) @map("sort_order")
  isCover       Boolean  @default(false) @map("is_cover")
  createdAt     DateTime @default(now()) @map("created_at")

  property Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])

  @@index([propertyId, sortOrder])
  @@map("property_images")
}

enum UnitType {
  STUDIO
  ONE_BED
  TWO_BED
  PENTHOUSE
  OTHER
}

model PropertyUnit {
  id              String     @id @default(uuid())
  propertyId      String     @map("property_id")
  unitNumber      String     @map("unit_number")
  unitType        UnitType   @map("unit_type")
  floor           Int?
  areaSqm         Decimal?   @map("area_sqm")
  baseNightlyRate Decimal    @map("base_nightly_rate")
  maxGuests       Int        @map("max_guests")
  status          PropertyStatus @default(ACTIVE)
  metadata        Json?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  property Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  images   PropertyImage[]
  bookings Booking[]
  calendarBlocks CalendarBlock[]
  icalFeeds  IcalFeed[]
  tasks    Task[]
  maintenanceRequests MaintenanceRequest[]
  iotDevices IotDevice[]
  ratePlans  RatePlan[]
  seasonalRates SeasonalRate[]

  @@index([propertyId])
  @@map("property_units")
}

// ==========================================
// 3. CUSTOM FIELDS
// ==========================================

enum FieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  URL
}

model CustomFieldDefinition {
  id          String    @id @default(uuid())
  entityType  String    @map("entity_type") // 'property', 'owner', 'booking'
  fieldKey    String    @map("field_key")
  fieldLabel  Json      @map("field_label") // Multilingual
  fieldType   FieldType @map("field_type")
  options     Json?     // For SELECT/MULTI_SELECT
  isRequired  Boolean   @default(false) @map("is_required")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  values CustomFieldValue[]

  @@unique([entityType, fieldKey])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id           String  @id @default(uuid())
  definitionId String  @map("definition_id")
  entityId     String  @map("entity_id")
  value        Json
  propertyId   String? @map("property_id") // For quick filtering
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  property   Property?             @relation(fields: [propertyId], references: [id])

  @@unique([definitionId, entityId])
  @@index([entityId])
  @@map("custom_field_values")
}

// ==========================================
// 4. OWNERS
// ==========================================

model Owner {
  id                         String   @id @default(uuid())
  userId                     String   @unique @map("user_id")
  companyName                String?  @map("company_name")
  taxId                      String?  @map("tax_id")
  billingAddress             Json?    @map("billing_address")
  defaultManagementFeePercent Decimal @default(25) @map("default_management_fee_percent")
  defaultMinimumMonthlyFee   Decimal  @default(0) @map("default_minimum_monthly_fee")
  expenseApprovalThreshold   Decimal  @default(100) @map("expense_approval_threshold")
  preferredPaymentMethod     PaymentMethodType @default(BANK_TRANSFER) @map("preferred_payment_method")
  bankDetails                Json?    @map("bank_details") // Encrypted
  stripeAccountId            String?  @map("stripe_account_id")
  paypalEmail                String?  @map("paypal_email")
  contractStartDate          DateTime? @map("contract_start_date")
  contractEndDate            DateTime? @map("contract_end_date")
  notes                      String?
  metadata                   Json?
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")
  deletedAt                  DateTime? @map("deleted_at")

  user                       User     @relation(fields: [userId], references: [id])
  properties                 Property[]
  incomeRecords              IncomeRecord[]
  expenseRecords             ExpenseRecord[]
  documents                  Document[]
  reportSchedules            ReportSchedule[]
  generatedReports           GeneratedReport[]
  affiliateReferrals         AffiliateReferral[] @relation("ReferredOwner")
  portfolioInvestments       PortfolioInvestment[]
  managementFeeCalcs         ManagementFeeCalculation[]
  messageThreads             MessageThread[]
  paymentTransactions        PaymentTransaction[] @relation("OwnerPayments")

  @@map("owners")
}

// ==========================================
// 5. BOOKINGS & CALENDAR
// ==========================================

enum BookingSource {
  DIRECT
  AIRBNB
  BOOKING_COM
  VRBO
  ICAL
  MANUAL
  WIDGET
}

enum BookingStatus {
  INQUIRY
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

model Booking {
  id                 String        @id @default(uuid())
  propertyId         String        @map("property_id")
  unitId             String?       @map("unit_id")
  guestId            String?       @map("guest_id")
  source             BookingSource @default(MANUAL)
  externalId         String?       @map("external_id")
  status             BookingStatus @default(PENDING)
  checkIn            DateTime      @map("check_in") @db.Date
  checkOut           DateTime      @map("check_out") @db.Date
  nights             Int
  guestsCount        Int           @map("guests_count")
  adults             Int           @default(1)
  children           Int           @default(0)
  infants            Int           @default(0)
  pets               Int           @default(0)
  nightlyRate        Decimal       @map("nightly_rate")
  subtotal           Decimal
  cleaningFee        Decimal       @default(0) @map("cleaning_fee")
  serviceFee         Decimal       @default(0) @map("service_fee")
  taxes              Decimal       @default(0)
  totalAmount        Decimal       @map("total_amount")
  currency           String        @default("EUR")
  paymentStatus      PaymentStatus @default(PENDING) @map("payment_status")
  guestName          String        @map("guest_name")
  guestEmail         String?       @map("guest_email")
  guestPhone         String?       @map("guest_phone")
  specialRequests    String?       @map("special_requests")
  internalNotes      String?       @map("internal_notes")
  icalUid            String?       @unique @map("ical_uid")
  confirmedAt        DateTime?     @map("confirmed_at")
  cancelledAt        DateTime?     @map("cancelled_at")
  cancellationReason String?       @map("cancellation_reason")
  metadata           Json?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  property   Property      @relation(fields: [propertyId], references: [id])
  unit       PropertyUnit? @relation(fields: [unitId], references: [id])
  guest      GuestProfile? @relation(fields: [guestId], references: [id])
  incomeRecords    IncomeRecord[]
  tasks            Task[]
  messageThreads   MessageThread[]
  loyaltyTransactions LoyaltyTransaction[]
  affiliateReferrals AffiliateReferral[] @relation("ReferredBooking")
  paymentTransactions PaymentTransaction[]
  guestScreenings  GuestScreening[]

  @@index([propertyId, checkIn, checkOut])
  @@index([guestEmail])
  @@index([status, checkIn])
  @@map("bookings")
}

enum BlockType {
  OWNER_BLOCK
  MAINTENANCE
  RENOVATION
  OTHER
}

model CalendarBlock {
  id          String    @id @default(uuid())
  propertyId  String    @map("property_id")
  unitId      String?   @map("unit_id")
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime  @map("end_date") @db.Date
  blockType   BlockType @map("block_type")
  reason      String?
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  property Property     @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])
  createdBy User        @relation(fields: [createdById], references: [id])

  @@index([propertyId, startDate, endDate])
  @@map("calendar_blocks")
}

enum SyncStatus {
  OK
  ERROR
  PENDING
}

model IcalFeed {
  id                  String     @id @default(uuid())
  propertyId          String     @map("property_id")
  unitId              String?    @map("unit_id")
  channelName         String     @map("channel_name")
  importUrl           String     @map("import_url")
  lastSyncedAt        DateTime?  @map("last_synced_at")
  syncStatus          SyncStatus @default(PENDING) @map("sync_status")
  syncError           String?    @map("sync_error")
  syncIntervalMinutes Int        @default(15) @map("sync_interval_minutes")
  isActive            Boolean    @default(true) @map("is_active")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  property Property     @relation(fields: [propertyId], references: [id])
  unit     PropertyUnit? @relation(fields: [unitId], references: [id])

  @@index([propertyId])
  @@map("ical_feeds")
}

// ==========================================
// 6. GUESTS
// ==========================================

enum ScreeningStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
}

enum ScreeningType {
  ID_VERIFICATION
  BACKGROUND_CHECK
  REFERENCE_CHECK
}

model GuestProfile {
  id            String           @id @default(uuid())
  firstName     String           @map("first_name")
  lastName      String           @map("last_name")
  email         String?
  phone         String?
  nationality   String?
  language      String?
  idType        String?          @map("id_type")
  idNumber      String?          @map("id_number") // Encrypted
  idExpiry      DateTime?        @map("id_expiry") @db.Date
  dateOfBirth   DateTime?        @map("date_of_birth") @db.Date
  address       Json?
  tags          Json?            // Array of strings
  totalStays    Int              @default(0) @map("total_stays")
  totalRevenue  Decimal          @default(0) @map("total_revenue")
  notes         String?
  screeningStatus ScreeningStatus? @map("screening_status")
  metadata      Json?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  bookings     Booking[]
  screenings   GuestScreening[]
  messageThreads MessageThread[]

  @@map("guest_profiles")
}

model GuestScreening {
  id             String          @id @default(uuid())
  guestId        String          @map("guest_id")
  bookingId      String?         @map("booking_id")
  screeningType  ScreeningType   @map("screening_type")
  provider       String?
  status         ScreeningStatus
  resultData     Json?           @map("result_data") // Encrypted
  verifiedById   String?         @map("verified_by_id")
  verifiedAt     DateTime?       @map("verified_at")
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at")

  guest   GuestProfile @relation(fields: [guestId], references: [id])
  booking Booking?     @relation(fields: [bookingId], references: [id])

  @@index([guestId])
  @@map("guest_screenings")
}

// ==========================================
// 7. FINANCE
// ==========================================

enum IncomeCategory {
  RENTAL
  CLEANING_FEE
  EXTRA_SERVICES
  DAMAGE_DEPOSIT
  LATE_CHECKOUT
  OTHER
}

model IncomeRecord {
  id          String         @id @default(uuid())
  propertyId  String         @map("property_id")
  bookingId   String?        @map("booking_id")
  ownerId     String         @map("owner_id")
  category    IncomeCategory
  amount      Decimal
  currency    String         @default("EUR")
  description String?
  date        DateTime       @db.Date
  periodMonth Int            @map("period_month")
  periodYear  Int            @map("period_year")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])
  owner    Owner    @relation(fields: [ownerId], references: [id])

  @@index([propertyId, periodYear, periodMonth])
  @@index([ownerId, periodYear, periodMonth])
  @@map("income_records")
}

enum ExpenseCategory {
  MAINTENANCE
  UTILITIES
  CLEANING
  SUPPLIES
  INSURANCE
  TAXES
  MANAGEMENT_FEE
  MARKETING
  EQUIPMENT
  OTHER
}

enum ApprovalStatus {
  AUTO_APPROVED
  PENDING
  APPROVED
  REJECTED
}

model ExpenseRecord {
  id                       String          @id @default(uuid())
  propertyId               String?         @map("property_id")
  ownerId                  String?         @map("owner_id")
  category                 ExpenseCategory
  amount                   Decimal
  currency                 String          @default("EUR")
  description              String
  date                     DateTime        @db.Date
  periodMonth              Int             @map("period_month")
  periodYear               Int             @map("period_year")
  vendor                   String?
  receiptUrl               String?         @map("receipt_url")
  approvalStatus           ApprovalStatus  @default(AUTO_APPROVED) @map("approval_status")
  approvalThresholdAtTime  Decimal?        @map("approval_threshold_at_time")
  approvedById             String?         @map("approved_by_id")
  approvedAt               DateTime?       @map("approved_at")
  whatsappApprovalMsgId    String?         @map("whatsapp_approval_msg_id")
  notes                    String?
  isRecurring              Boolean         @default(false) @map("is_recurring")
  recurrencePattern        String?         @map("recurrence_pattern") // monthly, yearly
  metadata                 Json?
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  property  Property?  @relation(fields: [propertyId], references: [id])
  owner     Owner?     @relation(fields: [ownerId], references: [id])
  approvedBy User?     @relation("ExpenseApprover", fields: [approvedById], references: [id])
  maintenanceRequest MaintenanceRequest?

  @@index([propertyId, periodYear, periodMonth])
  @@index([approvalStatus])
  @@map("expense_records")
}

enum FeeType {
  PERCENTAGE
  MINIMUM
}

enum FeeStatus {
  DRAFT
  APPROVED
  INVOICED
  PAID
}

model ManagementFeeCalculation {
  id            String    @id @default(uuid())
  ownerId       String    @map("owner_id")
  propertyId    String    @map("property_id")
  periodMonth   Int       @map("period_month")
  periodYear    Int       @map("period_year")
  totalIncome   Decimal   @map("total_income")
  feePercent    Decimal   @map("fee_percent")
  calculatedFee Decimal   @map("calculated_fee") // percent * income
  minimumFee    Decimal   @map("minimum_fee")
  appliedFee    Decimal   @map("applied_fee") // MAX(calculatedFee, minimumFee)
  feeType       FeeType   @map("fee_type") // Which one was applied
  status        FeeStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  owner    Owner    @relation(fields: [ownerId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([ownerId, propertyId, periodMonth, periodYear])
  @@map("management_fee_calculations")
}

// ==========================================
// 8. PAYMENTS
// ==========================================

enum PaymentMethodType {
  BANK_TRANSFER
  STRIPE
  PAYPAL
  CASH
  APPLE_PAY
  GOOGLE_PAY
}

enum TransactionType {
  BOOKING_PAYMENT
  OWNER_PAYOUT
  REFUND
  FEE_COLLECTION
  AFFILIATE_PAYOUT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model PaymentTransaction {
  id                    String            @id @default(uuid())
  bookingId             String?           @map("booking_id")
  ownerId               String?           @map("owner_id")
  type                  TransactionType
  provider              PaymentMethodType
  providerTransactionId String?           @map("provider_transaction_id")
  amount                Decimal
  currency              String            @default("EUR")
  status                TransactionStatus @default(PENDING)
  feeAmount             Decimal           @default(0) @map("fee_amount")
  metadata              Json?
  completedAt           DateTime?         @map("completed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id])
  owner   Owner?   @relation("OwnerPayments", fields: [ownerId], references: [id])

  @@index([bookingId])
  @@index([ownerId])
  @@map("payment_transactions")
}

model PaymentMethod {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  provider           PaymentMethodType
  providerMethodId   String            @map("provider_method_id")
  type               String            // 'card', 'bank_account', 'paypal'
  lastFour           String?           @map("last_four")
  brand              String?
  isDefault          Boolean           @default(false) @map("is_default")
  expiresAt          DateTime?         @map("expires_at")
